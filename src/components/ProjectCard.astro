---
interface Props {
  slug: string;
  title: string;
  subtitle: string;
  category: string;
  categoryLabel: string;
  year: number;
  coverGradient: string;
  coverImage?: string;
  featured?: boolean;
}

const { slug, title, subtitle, categoryLabel, year, coverGradient, coverImage } = Astro.props;
---

<article class="project-card">
  <a href={`/work/${slug}`} aria-label={title}>
    <!-- Image area -->
    <div class="card-image">
      {coverImage
        ? <img src={coverImage} alt={title} class="card-photo" />
        : <>
            <div class="card-gradient" style={`background: ${coverGradient};`}></div>
            <div class="card-grain"></div>
          </>
      }
      <!-- Hover arrow -->
      <div class="card-arrow">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>

    <!-- Text area -->
    <div class="card-body">
      <div class="card-meta">
        <span class="card-category">{categoryLabel}</span>
        <span class="card-year">{year}</span>
      </div>
      <h3 class="card-title">{title}</h3>
      <p class="card-subtitle">{subtitle}</p>
    </div>
  </a>
</article>

<style>
  .project-card a {
    display: block;
    color: inherit;
  }

  /* ── Image area ── */
  .card-image {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .card-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.7s var(--ease-out);
  }

  .project-card:hover .card-photo {
    transform: scale(1.04);
  }

  .card-gradient {
    position: absolute;
    inset: 0;
    transition: transform 0.7s var(--ease-out);
  }

  .project-card:hover .card-gradient {
    transform: scale(1.04);
  }

  .card-grain {
    position: absolute;
    inset: 0;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 160px;
  }

  /* Arrow: fades in on hover */
  .card-arrow {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    width: 32px;
    height: 32px;
    background: var(--color-surface);
    color: var(--color-ink);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translate(4px, 4px);
    transition: opacity 0.25s var(--ease-out), transform 0.25s var(--ease-out);
  }

  .project-card:hover .card-arrow {
    opacity: 1;
    transform: translate(0, 0);
  }

  /* ── Text area ── */
  .card-body {
    padding: 0.9rem 0 0.25rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.4rem;
  }

  .card-category {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .card-year {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    color: var(--color-ink-2);
  }

  .card-title {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.1rem;
    color: var(--color-ink);
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin-bottom: 0.3rem;
    transition: color 0.18s var(--ease-out);
  }

  .project-card:hover .card-title { color: var(--color-accent); }

  .card-subtitle {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-ink-2);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
