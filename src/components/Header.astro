---
import { navLinks } from '../data/navigation';

interface Props {
  activeNav?: string;
}

const { activeNav } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header id="site-header">
  <div class="container-content">
    <div class="header-inner">
      <!-- Logo -->
      <a href="/" class="logo-link">
        <span class="logo-name">Jimmy Qiu</span>
        <span class="logo-role">Imaginer</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="desktop-nav" aria-label="Primary navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'nav-link',
              {
                'active': activeNav === link.category ||
                  link.href === currentPath ||
                  (link.href.startsWith('/work') && currentPath.startsWith('/work') && !link.category),
              },
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Hamburger -->
      <button
        id="menu-toggle"
        class="hamburger"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar bar--short"></span>
      </button>
    </div>
  </div>
</header>

<!-- Push content below fixed header -->
<div style="height: 68px;"></div>

<style>
  #site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 30;
    background: rgba(246, 245, 241, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-rule);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
  }

  .logo-link {
    display: flex;
    flex-direction: column;
    line-height: 1;
    gap: 0.2rem;
  }
  .logo-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    transition: color 0.18s var(--ease-out);
  }
  .logo-link:hover .logo-name { color: var(--color-accent); }
  .logo-role {
    font-family: var(--font-sans);
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-ink-2);
    padding-left: 0.2rem;
  }

  .desktop-nav {
    display: none;
    align-items: center;
    gap: 1.75rem;
  }

  @media (min-width: 768px) {
    .desktop-nav { display: flex; }
    .hamburger { display: none; }
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
    background: none;
    border: none;
    cursor: pointer;
  }
  .bar {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--color-ink);
    transition: transform 0.25s var(--ease-out), opacity 0.25s;
  }
  .bar--short { width: 14px; }

  [data-menu-open="true"] .bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
    width: 22px;
  }
  [data-menu-open="true"] .bar:nth-child(2) {
    transform: rotate(-45deg);
  }
  [data-menu-open="true"] .bar:nth-child(3) {
    opacity: 0;
    transform: translateX(-6px);
  }
</style>
