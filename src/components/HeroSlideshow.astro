---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import heroImg1 from '../content/images/hdr_stills_sample1.jpg';
import heroImg2 from '../content/images/hdr_stills_sample2.jpg';
import heroImg3 from '../content/images/LOVE JENNIFER LOPEZ MORE IN DOLBY ATMOS.jpg';
import heroImg4 from '../content/images/ArtistryVersion_Dolby_Ed_Sheeran_Colin_Tilley1.jpg';
import heroImg5 from '../content/images/the_last_deal.jpg';
import heroImg6 from '../content/images/trinket_box1.jpg';
import heroImg7 from '../content/images/agx.jpg';

interface Slide {
  image?: ImageMetadata;
  gradient?: string;
  label?: string;
  title?: string;
  subtitle?: string;
  href?: string;
}

interface Props {
  slides?: Slide[];
  fullScreen?: boolean;
}

const {
  fullScreen = false,
  slides = [
    { image: heroImg1, title: 'HDR Stills', subtitle: 'iPadOS App', href: '/work/hdr-stills' },
    {
      image: heroImg7,
      title: 'AgX Emulsion',
      subtitle: 'OpenFX Plugin',
      href: '/work/agx-emulsion',
    },
    {
      image: heroImg3,
      gradient: 'radial-gradient(ellipse at 32% 58%, #162038 0%, #0c1525 55%, #050810 100%)',
      title: 'Love Jennifer Lopez More in Dolby Atmos',
      subtitle: 'Commercial',
      href: '/work/love-jennifer-lopez',
    },
    {
      image: heroImg4,
      title: 'Love Ed Sheeran More in Dolby Atmos',
      subtitle: 'Commercial',
      href: '/work/love-ed-sheeran',
    },
    {
      image: heroImg5,
      title: 'The Last Deal',
      subtitle: 'Feature',
      href: '/work/the-last-deal',
    },
    {
      image: heroImg6,
      title: 'Trinket Box',
      subtitle: 'Feature',
      href: '/work/trinket-box',
    },
  ],
} = Astro.props;
---

<!-- Hero sits flush to top (header is fixed above it) -->
<section class:list={['hero-section', { 'hero-full': fullScreen }]}>
  <div class="swiper hero-swiper">
    <div class="swiper-wrapper">
      {slides.map((slide) => (
        <div class="swiper-slide">
          <!-- Real photo or gradient fill -->
          {slide.image ? (
            <Image
              src={slide.image}
              alt=""
              class="slide-img"
              widths={[800, 1200, 1920]}
              sizes="100vw"
              loading="eager"
            />
          ) : (
            <div class="slide-bg" style={`background: ${slide.gradient};`}></div>
          )}

          <!-- Subtle film grain -->
          <div class="grain"></div>

          <!-- Edge vignette -->
          <div class="vignette"></div>

          <!-- Slide label: bottom-right, barely visible -->
          {slide.label && (
            <span class="slide-label">{slide.label}</span>
          )}

          <!-- Slide title overlay: bottom-left -->
          {slide.title && (
            <a class="slide-title-wrap" href={slide.href ?? '#'}>
              <span class="slide-title">{slide.title}</span>
              {slide.subtitle && <span class="slide-subtitle">{slide.subtitle}</span>}
            </a>
          )}
        </div>
      ))}
    </div>

    <div class="swiper-pagination"></div>
  </div>

</section>

<style>
  .hero-section {
    position: relative;
    /* Negative top margin pulls hero up behind fixed header */
    margin-top: -68px;
  }

  /* Full-screen mode (homepage — no header) */
  .hero-full {
    position: fixed;
    inset: 0;
    margin-top: 0;
  }
  .hero-full .hero-swiper {
    height: 100%;
  }

  .swiper-slide { position: relative; overflow: hidden; }

  .slide-bg,
  .slide-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transition: transform 8s ease-out;
  }

  .slide-img {
    object-fit: cover;
    object-position: center top;
  }

  /* Very slow Ken Burns on active gradient slide only */
  .swiper-slide-active .slide-bg {
    transform: scale(1.04);
  }

  .grain {
    position: absolute;
    inset: 0;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 300 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 220px;
  }

  .vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 45%, rgba(5,8,16,0.65) 100%);
  }

  .slide-title-wrap {
    position: absolute;
    bottom: 3.5rem;
    left: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    z-index: 3;
    text-decoration: none;
  }

  .slide-title {
    font-family: var(--font-sans);
    font-size: 2.2rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: rgba(246, 245, 241, 0.95);
    line-height: 1;
    transition: color 0.2s var(--ease-out);
  }

  .slide-subtitle {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: rgba(246, 245, 241, 0.5);
    padding-left: 0.1rem;
  }

  .slide-title-wrap:hover .slide-title {
    color: #fff;
  }

  .slide-label {
    position: absolute;
    bottom: 3.5rem;
    right: 2rem;
    font-family: var(--font-sans);
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(246, 245, 241, 0.22);
  }

</style>

<script>
  import Swiper from 'swiper';
  import { Autoplay, Pagination, EffectFade, Keyboard } from 'swiper/modules';

  function initHero() {
    if (!document.querySelector('.hero-swiper')) return;

    new Swiper('.hero-swiper', {
      modules: [Autoplay, Pagination, EffectFade, Keyboard],
      effect: 'fade',
      fadeEffect: { crossFade: true },
      loop: true,
      speed: 1000,
      autoplay: { delay: 4000, disableOnInteraction: false },
      pagination: { el: '.swiper-pagination', clickable: true },
      keyboard: { enabled: true },
    });
  }

  document.addEventListener('astro:page-load', initHero);
</script>
